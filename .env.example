# Environment Configuration
# Copy this file to .env and fill in your values

# Backend Configuration
DATABASE_URL=sqlite:///./recommender.db
# For PostgreSQL: postgresql://user:password@localhost:5432/recommender_db

REDIS_URL=redis://localhost:6379
# For production Redis: redis://:password@host:port

# JWT Secret (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend Configuration (for Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Recommender System

# ML Model Configuration
MODEL_VERSION=v1.0
MODEL_PATH=./ml/models/
CACHE_TTL=300

# A/B Testing
AB_TEST_ENABLED=true
DEFAULT_COHORT=A

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# Production Settings (uncomment for production)
# DATABASE_URL=postgresql://prod_user:prod_pass@prod-host:5432/prod_db
# REDIS_URL=redis://:prod_pass@prod-host:6379
# JWT_SECRET_KEY=production-secret-key-from-secrets-manager
# CORS_ORIGINS=https://yourdomain.com
# API_RELOAD=false
# LOG_LEVEL=WARNING
